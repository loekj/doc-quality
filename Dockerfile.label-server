FROM node:22-slim
WORKDIR /app

# Install sharp for HEIC→JPEG conversion (prebuilt binary, no build tools needed)
RUN npm init -y > /dev/null 2>&1 && npm install --save sharp && ls node_modules/sharp/lib/index.js

# Copy only the label server and fixtures
COPY test/fixtures/real/ ./test/fixtures/real/

# Labels persist on a volume mounted at /data
ENV PORT=3847
ENV LABELS_PATH=/data/labels.json

EXPOSE 3847
CMD ["node", "test/fixtures/real/label-server.mjs"]
